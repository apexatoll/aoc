#!/bin/bash

xTot=$(($(sed -n 1p input | wc -m) - 1))
yTot=$(cat input | wc -l)
xArr=(1 3 5 7 1)
yArr=(1 1 1 1 2)
treeSum=1

for i in ${!xArr[@]}; do
	trees=0
	xPos=1; yPos=1
	xMove=${xArr[$i]}; yMove=${yArr[$i]}
	while [ "$yPos" -le "$yTot" ]; do
		yPos=$((yPos + $yMove))
		xPos=$((xPos + $xMove))
		line=$(sed -n "$yPos"p input)
		if [ "$xPos" -gt "$xTot" ] ; then
			xPos=$((xPos - xTot))
		fi
		coord=${line:$((xPos - 1)):1}
		if [ "$coord" == "#" ]; then
			trees=$((trees + 1))
		fi
	done
	treeSum=$((treeSum * $trees))
done
echo $treeSum
