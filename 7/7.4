#!/bin/bash

loop=1
declare -A bagValues
main(){
	tree "shiny gold"
}
tree(){
	echo $loop
	line=$(grep "^$1" input)
	if echo $line | grep "no other"; then
		echo this bag is empty
	else IFS=";" read -rd '' -a contents<<<$(echo $line | sed -E 's/^.*bags contain (.*)\.$/\1/g; s/, /;/g')
		chain+=("$1")
		printf "%s\n" "${contents[@]}"
		echo ${chain[@]}
	fi
	let loop+=1
}
main; exit


















