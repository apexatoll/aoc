#!/bin/bash
#byr (Birth Year) - four digits; at least 1920 and at most 2002.
#iyr (Issue Year) - four digits; at least 2010 and at most 2020.
#eyr (Expiration Year) - four digits; at least 2020 and at most 2030.
#hgt (Height) - a number followed by either cm or in:
#"^.*(1([5-8][0-9]|9[0-3])cm|(59|6[0-9]|7[1-6])in).*$"
#If cm, the number must be at least 150 and at most 193.
#If in, the number must be at least 59 and at most 76.
#hcl (Hair Color) - a # followed by exactly six characters 0-9 or a-f.
#ecl (Eye Color) - exactly one of: amb blu brn gry grn hzl oth.
#pid (Passport ID) - a nine-digit number, including leading zeroes.
#cid (Country ID) - ignored, missing or not.
	#"hgt:(1(([5-8][0-9])(9[0-3]))cm|((59)(6[0-9])(7[0-6]))in)"

format=$(cat input | tr '\n' ';' | sed 's/;;/\n/g' | sed 's/;/ /g')
nLines=$(printf "%s\n" "$format" | wc -l)
valid=0
invalid=0
regex=(
	"byr:(19[2-9][0-9]|200[0-2])"
	"iyr:20(1[0-9]|20)"
	"eyr:20(2[0-9]|30)"
	"hgt:(1(([5-8][0-9])|(9[0-3]))cm|((59)|(6[0-9])|(7[0-6]))in)"
	"hcl:#[0-9a-f]{6}"
	"ecl:(amb|blu|brn|gry|grn|hzl|oth)"
	"pid:[0-9]{9}"
)
checkRegex(){
	for j in ${!regex[@]}; do
		echo "$1" | grep -E "^.*${regex[$j]}.*$" > /dev/null || { field="$j"; return 1; }
		#echo "$1" | grep -E "^.*${regex[$j]}.*$" > /dev/null && let regCount+=1
	done
	#if [ "$regCount" == 7 ]; then
		return 0
	#else
		#return 1j;
	#fi
}
for i in $(seq 1 $nLines); do 
	line=$(printf "$format" | sed -n "$i"p)
	numFields=$(echo $line | awk '{print NF}')
	count="$i"
	case $numFields in 
		7|8) checkRegex "$line" && { echo $line; echo valid; let valid+=1; echo $valid; } || { echo $line ; echo "invalid $(echo ${regex[$field]} | sed -E 's/^.*(byr|iyr|eyr|hgt|hcl|ecl|pid).*$/\1/')" ; };;
		#*) checkRegex "$line" && { echo $line; echo valid; let valid+=1; echo $valid; } || { echo $line ; echo "invalid $(echo ${regex[$field]} | sed -E 's/^.*(byr|iyr|eyr|hgt|hcl|ecl|pid).*$/\1/')" ; };;
		#7|8) checkRegex "$line" && { echo $line; echo valid; let valid+=1; echo $valid; };;
		#7|8) checkRegex "$line" || { echo $line ; echo "invalid $(echo ${regex[$field]} | sed -E 's/^.*(byr|iyr|eyr|hgt|hcl|ecl|pid).*$/\1/')" ; };;

		#7|8) checkRegex "$line" && let valid+=1 || let invalid+=1;;
		#*) let invalid+=1
	esac
done
echo $valid
echo $invalid
